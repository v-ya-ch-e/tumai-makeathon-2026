# Copy to .env and fill in.

# --- Database (AWS-hosted MySQL RDS, shared by backend + scraper) ---
# All five vars are required. `backend/app/wg_agent/db.py` assembles the
# DSN (mysql+pymysql://user:password@host:port/name?charset=utf8mb4) at
# import time and refuses to boot if any are missing or empty.
# Ask a teammate for the real values; do NOT commit them.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- OpenAI (used by the WG Hunter agent) ---
OPENAI_API_KEY=

# Optional: override the default model. gpt-4o-mini is fine for most demos;
# use gpt-4o for stronger German intro messages.
# OPENAI_MODEL=gpt-4o-mini

# --- Google Maps (Places Autocomplete in the onboarding wizard) ---
# Restrict the key in Google Cloud Console to:
#   * Application: HTTP referrers -> localhost + your deployed origin
#   * APIs: "Maps JavaScript API" and "Places API (New)"
# The VITE_ prefix exposes the key to the browser bundle, which is fine
# because the key is referrer + API restricted.
VITE_GOOGLE_MAPS_API_KEY=


# --- Google Maps Platform (server-side geocoding + commute + nearby places) ---
# Restrict the backend key in Google Cloud Console to:
#   * Application: IP addresses (backend hosts only)
#   * APIs: "Geocoding API", "Distance Matrix API", "Places API (New)"
# This key is read only on the backend and must not use the VITE_ prefix.
# If unset, listings still scrape, but commute times and nearby-place
# enrichment become missing data.
GOOGLE_MAPS_SERVER_KEY=AIza...

# Optional: keep backend Google traffic comfortably under your configured
# project quota / QPS ceiling. Defaults to 8 req/s when unset.
# GOOGLE_MAPS_MAX_RPS=8

# --- wg-gesucht session cookies (optional, reserved for authenticated flows) ---
# Point this at a Playwright storage_state.json produced by logging in once
# manually. See docs/WG_GESUCHT.md. v1 runs anonymously and ignores this.
# WG_STATE_FILE=/absolute/path/to/wg_state.json

# --- Scraper agent (background scraper container) ---
# City + permissive rent ceiling used to build the scraper's search profile.
# Pages of search results per pass, seconds between passes, hours before a
# listing is re-scraped to refresh prices / availability.
# SCRAPER_CITY=München
# SCRAPER_MAX_RENT=2000
# SCRAPER_MAX_PAGES=2
# SCRAPER_INTERVAL_SECONDS=300
# SCRAPER_REFRESH_HOURS=24

# Comma-separated list of source plugins to run; default is wg-gesucht only
# so today's deployment is unchanged unless you opt in to the new sources.
# Valid names: wg-gesucht, tum-living, kleinanzeigen.
# SCRAPER_ENABLED_SOURCES=wg-gesucht,tum-living,kleinanzeigen

# Drop listings whose posting date is older than this many days. Default 14.
# Posting date is parsed per source: wg-gesucht from the search-card
# `Online: <relative-or-absolute>` field; tum-living from GraphQL
# publicationDate; kleinanzeigen from the detail-page `#viewad-extra-info`
# (so KA stale-drops happen after the detail fetch — small wasted work).
# SCRAPER_MAX_AGE_DAYS=14

# --- (optional) AWS Bedrock credentials for the makeathon challenge ---
# The WG Hunter uses OpenAI, but the repo is set up so you can swap in Bedrock
# later. These are read automatically by boto3 when present.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# --- Email notifications (Amazon SES) ---
# Used by backend/app/wg_agent/notifier.py to email users when a new match
# scores at or above WG_NOTIFY_THRESHOLD. See DEPLOYMENT.md for the one-time
# SES setup (verify the sender domain, request production access, create an
# IAM user with ses:SendEmail). All three AWS_* are read automatically by
# boto3; leaving them blank silently disables notifications.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# Sender identity. Must be a verified SES email or domain in AWS_DEFAULT_REGION.
SES_FROM_EMAIL=noreply@doubleu.team

# Minimum match score that triggers an email (inclusive: score >= threshold).
WG_NOTIFY_THRESHOLD=0.9

# Minimum wall-clock gap between digest emails per user (in minutes). The
# matcher batches every above-threshold new listing found during a pass and
# sends them together; if another pass completes before this cooldown expires,
# the pending digest is held and flushed on the next eligible pass.
# Listings whose `first_seen_at <= user.created_at` are excluded, so the
# initial post-signup scoring pass never emails — only genuinely new listings
# (whether discovered by the server scraper or a laptop-run scraper) do.
WG_NOTIFY_COOLDOWN_MINUTES=5

# Global floor on the per-user matcher poll interval (minutes). Overrides the
# per-profile value when set, so a new listing turns into an email within a
# few minutes of being scraped.
WG_RESCAN_INTERVAL_MINUTES=3

# Set to 1 to expose GET /api/debug/send-test-email?to=... for SES smoke tests.
# Keep at 0 in production.
ENABLE_EMAIL_DEBUG=0
