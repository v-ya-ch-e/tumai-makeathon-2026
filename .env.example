# Copy to .env and fill in.

# --- OpenAI (used by the WG Hunter agent) ---
OPENAI_API_KEY=

# Optional: override the default model. gpt-4o-mini is fine for most demos;
# use gpt-4o for stronger German intro messages.
# OPENAI_MODEL=gpt-4o-mini

# --- Google Maps (Places Autocomplete in the onboarding wizard) ---
# Restrict the key in Google Cloud Console to:
#   * Application: HTTP referrers -> localhost + your deployed origin
#   * APIs: "Maps JavaScript API" and "Places API (New)"
# The VITE_ prefix exposes the key to the browser bundle, which is fine
# because the key is referrer + API restricted.
VITE_GOOGLE_MAPS_API_KEY=


# --- Google Maps Platform (server-side geocoding + commute + nearby places) ---
# Restrict the backend key in Google Cloud Console to:
#   * Application: IP addresses (backend hosts only)
#   * APIs: "Geocoding API", "Distance Matrix API", "Places API (New)"
# This key is read only on the backend and must not use the VITE_ prefix.
# If unset, listings still scrape, but commute times and nearby-place
# enrichment become missing data.
GOOGLE_MAPS_SERVER_KEY=AIza...

# Optional: keep backend Google traffic comfortably under your configured
# project quota / QPS ceiling. Defaults to 8 req/s when unset.
# GOOGLE_MAPS_MAX_RPS=8

# --- wg-gesucht session cookies (optional, reserved for authenticated flows) ---
# Point this at a Playwright storage_state.json produced by logging in once
# manually. See docs/WG_GESUCHT.md. v1 runs anonymously and ignores this.
# WG_STATE_FILE=/absolute/path/to/wg_state.json

# --- (optional) AWS Bedrock credentials for the makeathon challenge ---
# The WG Hunter uses OpenAI, but the repo is set up so you can swap in Bedrock
# later. These are read automatically by boto3 when present.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
