      "PlaceLocation": {
        "description": "A user-picked location anchored by a Google Places place_id.\n\nProduced by the frontend's Places Autocomplete widget and stored as\nJSON in `SearchProfileRow.main_locations`. The lat/lng pair is what\ncommute-based scoring consumes; `label` is what we show to the user\nand the LLM. `max_commute_minutes` is an optional per-location\nbudget the scorer treats as a soft upper bound.",
        "properties": {
          "label": {
            "title": "Label",
            "type": "string"
          },
          "lat": {
            "title": "Lat",
            "type": "number"
          },
          "lng": {
            "title": "Lng",
            "type": "number"
          },
          "max_commute_minutes": {
            "anyOf": [
              {
                "maximum": 240.0,
                "minimum": 5.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Commute Minutes"
          },
          "place_id": {
            "title": "Place Id",
            "type": "string"
          }
        },
        "required": [
          "label",
          "place_id",
          "lat",
          "lng"
        ],
        "title": "PlaceLocation",
        "type": "object"
      },
      "PreferenceWeight": {
        "description": "One preference tag plus how important it is to the user.\n\n`key` matches the UI tile id (e.g. 'gym', 'furnished'). `weight`\nruns 1..5 where 5 is a hard filter and 1 is a mild bonus. Stored\ninside `SearchProfileRow.preferences` as `{key, weight}` objects.",
        "properties": {
          "key": {
            "title": "Key",
            "type": "string"
          },
          "weight": {
            "default": 3,
            "maximum": 5.0,
            "minimum": 1.0,
            "title": "Weight",
            "type": "integer"
          }
        },
        "required": [
          "key"
        ],
        "title": "PreferenceWeight",
        "type": "object"
      },
